{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-teams.local/schemas/hosted-web/evidence-catalog.schema.json",
  "title": "Hosted-web evidence catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "catalogId", "canonicalSha", "entries"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "catalogId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "canonicalSha": { "const": "42ec333848e29e97c41699b9fed73ed199740e3f" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "evidenceId": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]*$" },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "phaseId",
        "laneId",
        "authority",
        "producer",
        "producerBaseSha",
        "sha256",
        "regenerationCommand",
        "reviewDisposition",
        "supersession"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/evidenceId" },
        "path": { "$ref": "#/$defs/relativePath" },
        "phaseId": { "type": "string", "pattern": "^phase-[0-9]{2}$" },
        "laneId": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "authority": {
          "enum": ["canonical", "raw", "generated", "historical", "rejected", "superseded"]
        },
        "producer": { "type": "string", "minLength": 1 },
        "producerBaseSha": { "$ref": "#/$defs/sha1" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "regenerationCommand": {
          "oneOf": [{ "type": "string", "pattern": "^\\S(?:.*\\S)?$" }, { "type": "null" }]
        },
        "reviewDisposition": {
          "enum": [
            "pending",
            "approved",
            "approved-with-conditions",
            "rejected",
            "superseded",
            "not-required"
          ]
        },
        "supersession": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supersedes", "supersededBy"],
          "properties": {
            "supersedes": {
              "type": "array",
              "items": { "$ref": "#/$defs/evidenceId" },
              "uniqueItems": true
            },
            "supersededBy": {
              "oneOf": [{ "$ref": "#/$defs/evidenceId" }, { "type": "null" }]
            }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "authority": { "const": "generated" } } },
          "then": {
            "properties": {
              "regenerationCommand": { "type": "string", "pattern": "^\\S(?:.*\\S)?$" }
            }
          }
        },
        {
          "if": { "properties": { "authority": { "const": "canonical" } } },
          "then": {
            "properties": {
              "reviewDisposition": { "enum": ["approved", "approved-with-conditions"] },
              "supersession": { "properties": { "supersededBy": { "type": "null" } } }
            }
          }
        },
        {
          "if": { "properties": { "authority": { "const": "rejected" } } },
          "then": {
            "properties": {
              "reviewDisposition": { "const": "rejected" },
              "supersession": { "properties": { "supersededBy": { "type": "null" } } }
            }
          }
        },
        {
          "if": { "properties": { "authority": { "const": "superseded" } } },
          "then": {
            "properties": {
              "reviewDisposition": { "const": "superseded" },
              "supersession": {
                "properties": { "supersededBy": { "$ref": "#/$defs/evidenceId" } }
              }
            }
          },
          "else": {
            "properties": {
              "supersession": { "properties": { "supersededBy": { "type": "null" } } }
            }
          }
        },
        {
          "if": {
            "properties": {
              "supersession": {
                "properties": { "supersedes": { "minItems": 1 } },
                "required": ["supersedes"]
              }
            },
            "required": ["supersession"]
          },
          "then": {
            "properties": {
              "authority": { "const": "canonical" },
              "reviewDisposition": { "enum": ["approved", "approved-with-conditions"] }
            }
          }
        }
      ]
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!\\./)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\\\*?\\[\\]{}])[^/].*[^/]$|^[^/\\\\*?\\[\\]{}]$"
    }
  }
}
