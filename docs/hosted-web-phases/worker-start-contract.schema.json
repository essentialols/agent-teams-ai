{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-teams.local/schemas/hosted-web/worker-start-contract.schema.json",
  "title": "Hosted-web worker-start contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "jobId",
    "workerId",
    "canonicalSha",
    "baseSha",
    "phaseStartSha",
    "packetRevision",
    "controllerPacket",
    "lanePacket",
    "phaseId",
    "laneId",
    "inputPatchHash",
    "reviewKind",
    "revision",
    "retryCount",
    "workKey",
    "supersedes",
    "registryStatus",
    "jobRoot",
    "promptPath",
    "ownedPaths",
    "mandatoryDocs",
    "mandatoryScripts",
    "mandatoryFixtures",
    "requiredChecks",
    "executionPolicy"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "jobId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "workerId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "canonicalSha": { "const": "42ec333848e29e97c41699b9fed73ed199740e3f" },
    "baseSha": { "const": "42ec333848e29e97c41699b9fed73ed199740e3f" },
    "phaseStartSha": { "$ref": "#/$defs/sha1" },
    "packetRevision": { "enum": ["phase-00-r2", "phase-00-r3"] },
    "controllerPacket": { "const": "docs/hosted-web-phase-0-execution-packet.md" },
    "lanePacket": {
      "enum": [
        "docs/hosted-web-phases/phase-00/lanes/w1-parity-renderer.md",
        "docs/hosted-web-phases/phase-00/lanes/w2-provider-runtime.md",
        "docs/hosted-web-phases/phase-00/lanes/w3-state-writers-backup.md",
        "docs/hosted-web-phases/phase-00/lanes/w4-lease-guard-process.md",
        "docs/hosted-web-phases/phase-00/lanes/w5-events-commands-recovery.md",
        "docs/hosted-web-phases/phase-00/lanes/w6-auth-proxy-artifacts.md"
      ]
    },
    "phaseId": { "const": "phase-00" },
    "laneId": { "enum": ["w1", "w2", "w3", "w4", "w5", "w6"] },
    "inputPatchHash": { "$ref": "#/$defs/sha256" },
    "reviewKind": { "enum": ["implementation", "review", "remediation"] },
    "revision": { "type": "integer", "minimum": 0 },
    "retryCount": { "type": "integer", "minimum": 0 },
    "workKey": { "$ref": "#/$defs/sha256" },
    "supersedes": { "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "registryStatus": { "const": "queued" },
    "jobRoot": { "$ref": "#/$defs/absolutePath" },
    "promptPath": { "$ref": "#/$defs/absolutePath" },
    "ownedPaths": { "$ref": "#/$defs/nonEmptyPathList" },
    "mandatoryDocs": {
      "allOf": [
        { "$ref": "#/$defs/boundedReadPathList" },
        { "contains": { "const": "AGENTS.md" } },
        { "contains": { "const": "docs/hosted-web-phases/START_HERE.md" } },
        { "contains": { "const": "docs/hosted-web-phases/EVIDENCE_LIFECYCLE.md" } },
        { "contains": { "const": "docs/hosted-web-phases/README.md" } },
        { "contains": { "const": "docs/hosted-web-phases/EXECUTION_INDEX.json" } },
        { "contains": { "const": "docs/hosted-web-phase-0-execution-packet.md" } }
      ]
    },
    "mandatoryScripts": { "$ref": "#/$defs/boundedReadPathList" },
    "mandatoryFixtures": { "$ref": "#/$defs/boundedReadPathList" },
    "requiredChecks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "cwd", "command"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "cwd": { "$ref": "#/$defs/relativePath" },
          "command": { "type": "string", "pattern": "^\\S(?:.*\\S)?$" }
        }
      }
    },
    "executionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "sandboxRoot", "forbiddenRealProjects"],
      "properties": {
        "mode": { "const": "sandbox-only" },
        "sandboxRoot": { "$ref": "#/$defs/absolutePath" },
        "forbiddenRealProjects": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "contains": { "const": "~/dev/projects/ai/claude-runtime" },
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "revision": { "const": 0 } } },
      "then": {
        "properties": {
          "retryCount": { "const": 0 },
          "supersedes": { "type": "null" }
        }
      },
      "else": {
        "properties": {
          "retryCount": { "type": "integer", "minimum": 1 },
          "supersedes": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    {
      "if": { "properties": { "laneId": { "const": "w1" } } },
      "then": {
        "properties": {
          "lanePacket": {
            "const": "docs/hosted-web-phases/phase-00/lanes/w1-parity-renderer.md"
          },
          "mandatoryDocs": {
            "contains": {
              "const": "docs/hosted-web-phases/phase-00/lanes/w1-parity-renderer.md"
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "laneId": { "const": "w2" } } },
      "then": {
        "properties": {
          "lanePacket": {
            "const": "docs/hosted-web-phases/phase-00/lanes/w2-provider-runtime.md"
          },
          "mandatoryDocs": {
            "contains": {
              "const": "docs/hosted-web-phases/phase-00/lanes/w2-provider-runtime.md"
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "laneId": { "const": "w3" } } },
      "then": {
        "properties": {
          "lanePacket": {
            "const": "docs/hosted-web-phases/phase-00/lanes/w3-state-writers-backup.md"
          },
          "mandatoryDocs": {
            "contains": {
              "const": "docs/hosted-web-phases/phase-00/lanes/w3-state-writers-backup.md"
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "laneId": { "const": "w4" } } },
      "then": {
        "properties": {
          "lanePacket": {
            "const": "docs/hosted-web-phases/phase-00/lanes/w4-lease-guard-process.md"
          },
          "mandatoryDocs": {
            "contains": {
              "const": "docs/hosted-web-phases/phase-00/lanes/w4-lease-guard-process.md"
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "laneId": { "const": "w5" } } },
      "then": {
        "properties": {
          "lanePacket": {
            "const": "docs/hosted-web-phases/phase-00/lanes/w5-events-commands-recovery.md"
          },
          "mandatoryDocs": {
            "contains": {
              "const": "docs/hosted-web-phases/phase-00/lanes/w5-events-commands-recovery.md"
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "laneId": { "const": "w6" } } },
      "then": {
        "properties": {
          "lanePacket": {
            "const": "docs/hosted-web-phases/phase-00/lanes/w6-auth-proxy-artifacts.md"
          },
          "mandatoryDocs": {
            "contains": {
              "const": "docs/hosted-web-phases/phase-00/lanes/w6-auth-proxy-artifacts.md"
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "absolutePath": { "type": "string", "pattern": "^/" },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!\\./)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*[\\\\*?\\[\\]{}])[^/].*[^/]$|^[^/\\\\*?\\[\\]{}]$"
    },
    "nonEmptyPathList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relativePath" }
    },
    "boundedReadPath": {
      "allOf": [
        { "$ref": "#/$defs/relativePath" },
        {
          "not": {
            "enum": ["docs", "docs/research", "docs/research/hosted-web"]
          }
        }
      ]
    },
    "boundedReadPathList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/boundedReadPath" }
    }
  }
}
