{
  "name": "@vioxen/subscription-runtime",
  "version": "0.1.0-main.2",
  "description": "Provider-neutral subscription runtime for backend workers, Codex subscription execution, and pluggable session custody.",
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vioxen/subscription-runtime.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./agent-task": {
      "types": "./dist/agent-task/index.d.ts",
      "import": "./dist/agent-task/index.js",
      "default": "./dist/agent-task/index.js"
    },
    "./account-diagnostics": {
      "types": "./dist/account-diagnostics/index.d.ts",
      "import": "./dist/account-diagnostics/index.js",
      "default": "./dist/account-diagnostics/index.js"
    },
    "./provider-codex": {
      "types": "./dist/provider-codex/index.d.ts",
      "import": "./dist/provider-codex/index.js",
      "default": "./dist/provider-codex/index.js"
    },
    "./openai-compatible-codex": {
      "types": "./dist/openai-compatible-codex/index.d.ts",
      "import": "./dist/openai-compatible-codex/index.js",
      "default": "./dist/openai-compatible-codex/index.js"
    },
    "./provider-claude": {
      "types": "./dist/provider-claude/index.d.ts",
      "import": "./dist/provider-claude/index.js",
      "default": "./dist/provider-claude/index.js"
    },
    "./worker-core": {
      "types": "./dist/worker-core/index.d.ts",
      "import": "./dist/worker-core/index.js",
      "default": "./dist/worker-core/index.js"
    },
    "./worker-codex": {
      "types": "./dist/worker-codex/index.d.ts",
      "import": "./dist/worker-codex/index.js",
      "default": "./dist/worker-codex/index.js"
    },
    "./worker-claude": {
      "types": "./dist/worker-claude/index.d.ts",
      "import": "./dist/worker-claude/index.js",
      "default": "./dist/worker-claude/index.js"
    },
    "./worker-local": {
      "types": "./dist/worker-local/index.d.ts",
      "import": "./dist/worker-local/index.js",
      "default": "./dist/worker-local/index.js"
    },
    "./queue-core": {
      "types": "./dist/queue-core/index.d.ts",
      "import": "./dist/queue-core/index.js",
      "default": "./dist/queue-core/index.js"
    },
    "./queue-bullmq": {
      "types": "./dist/queue-bullmq/index.d.ts",
      "import": "./dist/queue-bullmq/index.js",
      "default": "./dist/queue-bullmq/index.js"
    },
    "./store-local-file": {
      "types": "./dist/store-local-file/index.d.ts",
      "import": "./dist/store-local-file/index.js",
      "default": "./dist/store-local-file/index.js"
    },
    "./store-github-actions-secret": {
      "types": "./dist/store-github-actions-secret/index.d.ts",
      "import": "./dist/store-github-actions-secret/index.js",
      "default": "./dist/store-github-actions-secret/index.js"
    },
    "./runner-github-action": {
      "types": "./dist/runner-github-action/index.d.ts",
      "import": "./dist/runner-github-action/index.js",
      "default": "./dist/runner-github-action/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./testing/contracts": {
      "types": "./dist/testing/contracts.d.ts",
      "import": "./dist/testing/contracts.js",
      "default": "./dist/testing/contracts.js"
    },
    "./testing/fakes": {
      "types": "./dist/testing/fakes.d.ts",
      "import": "./dist/testing/fakes.js",
      "default": "./dist/testing/fakes.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "subscription-runtime-codex-goal": "./dist/worker-codex/codex-goal-cli.js",
    "subscription-runtime-codex-goal-mcp": "./dist/worker-codex/codex-goal-mcp.js",
    "subscription-runtime-openai-codex-bridge": "./dist/openai-compatible-codex/cli.js",
    "subscription-runtime-agent-task": "./dist/agent-task/cli.js",
    "subscription-runtime-account-status": "./dist/worker-local/account-diagnostics-cli.js",
    "subscription-runtime-run-agent-task": "./dist/worker-local/agent-task-runner-cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "LICENSE"
  ],
  "bundleDependencies": [
    "@vioxen/agent-account-observability"
  ],
  "scripts": {
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean:dist && npm run build:packages && tsc -p tsconfig.build.json && node scripts/rewrite-dist-esm-imports.mjs",
    "build:packages": "npm run --prefix packages/agent-account-observability build",
    "prepack": "npm run build",
    "typecheck": "npm run build:packages && tsc --noEmit -p tsconfig.json && npm run typecheck:packages",
    "typecheck:packages": "npm run --prefix packages/agent-account-observability typecheck",
    "test": "npm run build:packages && vitest run && npm run test:packages",
    "test:packages": "npm run --prefix packages/agent-account-observability test",
    "e2e:live-workers": "npm run build && node scripts/e2e-live-workers/run.mjs",
    "e2e:live-workers:dist": "node scripts/e2e-live-workers/run.mjs",
    "ops:codex-account-quota": "node scripts/ops/codex-account-quota-table.mjs",
    "ops:sync-codex-auth": "node scripts/ops/sync-codex-auth-to-host.mjs",
    "smoke:worker-claude": "npm run build && node scripts/smoke-claude-worker.mjs",
    "smoke:worker-claude-thread": "npm run build && CLAUDE_WORKER_SMOKE_MODE=thread node scripts/smoke-claude-worker.mjs",
    "check:boundaries": "node scripts/check-boundaries.mjs && node scripts/check-boundaries-self-test.mjs && npm run check:architecture-guardrails",
    "check:diff": "node scripts/check-git-diff.mjs",
    "check:dist-policy": "node scripts/check-dist-policy.mjs && node scripts/check-dist-policy-self-test.mjs",
    "check:dist": "node scripts/check-dist.mjs",
    "check:packed-consumer": "node scripts/check-packed-consumer.mjs",
    "check": "npm run check:diff && npm run check:dist-policy && npm run typecheck && npm run build && npm run check:dist && npm test && npm run check:boundaries && npm pack --dry-run && npm run check:packed-consumer",
    "check:architecture-guardrails": "node scripts/check-architecture-guardrails.mjs && node scripts/check-architecture-guardrails-self-test.mjs"
  },
  "dependencies": {
    "@vioxen/agent-account-observability": "file:packages/agent-account-observability",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.20.0",
    "libsodium-wrappers": "^0.8.4",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "claude-runtime": "0.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependenciesMeta": {
    "claude-runtime": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
